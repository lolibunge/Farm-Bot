{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "functions": {
    "api/telegram/*.js": {
      "maxDuration": 30
    },
    "api/reminders.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/admin-v2/stock-dashboard", "destination": "/api/admin-v2/horses?_view=stock" }
  ],
  "crons": [
    {
      "path": "/api/reminders",
      "schedule": "0 9 * * *"
    }
  ]
}
