# Telegram
TELEGRAM_BOT_TOKEN=

# Webhook security
# TELEGRAM_WEBHOOK_SECRET is used in the webhook path: /api/telegram/<secret>
TELEGRAM_WEBHOOK_SECRET=

# TELEGRAM_SETUP_SECRET protects the one-time setup route: /api/telegram/setup?secret=<setup_secret>
TELEGRAM_SETUP_SECRET=

# Database
DATABASE_URL=

# Admin panel
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_SECONDS=43200

# Optional alert chat
TELEGRAM_ALERT_CHAT_ID=

# Optional thresholds
DEWORM_ALERT_DAYS_AHEAD=3
LOW_STOCK_THRESHOLD=5
ALERT_CHECK_INTERVAL_MINUTES=60

# Optional cron protection
CRON_SECRET=
